{
  "$schema": "https://turbo.build/schema.json",
  "extends": ["//"],
  "tasks": {
    "build": {
      "dependsOn": ["t3#build"],
      "outputs": ["dist/**", "dist-webview/**", "dist-server/**"],
    },
    "dev": {
      "dependsOn": ["t3#build"],
      "persistent": true,
    },
    "package": {
      "dependsOn": ["build"],
      "outputs": ["*.vsix"],
    },
  },
}
